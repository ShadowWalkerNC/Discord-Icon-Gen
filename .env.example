# ============================================================
#  Sigil — Environment Variables
#  Copy to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ── Discord (Required) ────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id

# ── Web Server (Required) ──────────────────────────────────────
# Your public-facing URL — used for GUI links posted inside Discord
# Railway: set this to your Railway public domain
GUI_URL=https://sigil.up.railway.app

# Port for the Express web server. Default: 8080
PORT=8080

# ── GUI Authentication (Required) ─────────────────────────────
# Bearer token required for all /api/* and /ws/* requests.
# Generate with: openssl rand -hex 32
# Set this in Railway dashboard under Variables.
# Without this, all API endpoints return 503.
GUI_AUTH_TOKEN=your_long_random_secret_here

# ── Database ────────────────────────────────────────────────────
# Path to SQLite file. Default: data/sigil.db
# IMPORTANT: Mount a Railway Volume at /app/data to persist across deploys.
# DB_PATH=data/sigil.db

# ── Security ─────────────────────────────────────────────────
# Required for POST /api/control/restart and /api/control/deploy-commands
# Set this to a long random string (e.g. openssl rand -hex 32)
CONTROL_SECRET=your_control_secret_here

# Secret for validating inbound webhooks (general)
# WEBHOOK_SECRET=your_webhook_secret

# ── AI — Anthropic Claude (optional) ────────────────────────────
# Enables /mood, /palette, /saveme, /history and all AI generation features.
# Using Anthropic aligns Sigil with the ShadowRealm Network AI stack.
# Get your key at: https://console.anthropic.com/
#
# Future: route AI calls through ShadowRealm's /v1/generate endpoint
# instead of calling Anthropic directly. Set SRN_REGISTRY_URL below
# and remove ANTHROPIC_API_KEY once that routing is live.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── ShadowRealm Network (optional) ──────────────────────────────
# When ShadowRealm's AI routing is live, Sigil will forward AI calls
# to this endpoint instead of calling Anthropic directly.
# SRN_REGISTRY_URL=https://your-shadowrealm-instance.example.com
# SRN_AUTH_TOKEN=your_srn_auth_token_here

# ── YouTube (optional) ─────────────────────────────────────────
# Enables YouTube upload alert poller (/youtube setup)
# Get your key at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# ── Twitch (optional) ──────────────────────────────────────────
# Enables Twitch live alert poller (/twitch setup)
# Register your app at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# ── Bible API (optional) ───────────────────────────────────────
# Enables /devotional, /bible, /sermon verse fetching via API.Bible
# Bot gracefully disables the faith package if this key is absent.
BIBLE_API_KEY=your_api_bible_key_here
# Default Bible translation ID (NIV = de4e12af7f28f599-02)
BIBLE_ID=de4e12af7f28f599-02

# ── CulinaryOS Bridge (optional) ──────────────────────────────
# Enables /menu, /recipe, /inventory commands.
# Commands are hidden in Discord until both vars are set AND CulinaryOS is live.
CULINARYOS_API_URL=https://your-culinaryos-backend.example.com
CULINARYOS_API_KEY=your_culinaryos_api_key
# Shared secret for inbound CulinaryOS webhooks
CULINARYOS_WEBHOOK_SECRET=your_shared_secret_here

# ── Post-Pilot Bridge (optional) ──────────────────────────────
# Enables /post and /poststatus commands for AI social media generation
POSTPILOT_URL=https://your-postpilot-instance.example.com
POSTPILOT_API_KEY=your_postpilot_api_key
POSTPILOT_USER_ID=your_postpilot_user_id
# POSTPILOT_SRN_APP=sigil
# POSTPILOT_TIMEOUT_MS=12000

# ── Discord OAuth login (recommended for production) ──────────
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_REDIRECT_URI=https://YOUR-DOMAIN/auth/discord/callback
DISCORD_OAUTH_URL=https://discord.com/api/oauth2/authorize?client_id=YOUR_CLIENT_ID&redirect_uri=YOUR_REDIRECT_URI&response_type=code&scope=identify

# ── Railway / Production ──────────────────────────────────────
# NODE_ENV is set automatically by Railway.
# Set manually for local production testing:
# NODE_ENV=production
