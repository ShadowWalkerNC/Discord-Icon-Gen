# ============================================================
#  Sigil — Environment Variables
#  Copy to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id

# ── Database ─────────────────────────────────────────────────
# Path to SQLite file. Default: data/sigil.db
# DB_PATH=data/sigil.db

# ── Express / HTTP Server ────────────────────────────────────
# Port for the Sigil web server (GUI + webhooks). Default: 3420
PORT=3420

# ── Bible API (for /devotional) ──────────────────────────────
BIBLE_API_KEY=your_api_bible_key_here
# Default Bible ID (NIV = de4e12af7f28f599-02)
BIBLE_ID=de4e12af7f28f599-02

# ── Gemini AI (optional — for AI features) ───────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── CulinaryOS Bridge ────────────────────────────────────────
# Shared secret for inbound CulinaryOS webhooks (optional but recommended)
CULINARYOS_WEBHOOK_SECRET=your_shared_secret_here

# ── Webhook Security (general inbound webhooks) ──────────────
# WEBHOOK_SECRET=your_webhook_secret

# ── Railway / Production ─────────────────────────────────────
# NODE_ENV is set automatically by Railway. You can set it manually:
# NODE_ENV=production
